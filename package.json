{
  "name": "the-forge-flow",
  "version": "0.7.0",
  "description": "Autonomous coding agent orchestrator for Claude Code",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup --config tools/tsup.config.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tools/tsconfig.json",
    "lint": "biome check tools/src/",
    "lint:fix": "biome check --fix tools/src/",
    "format": "biome format --write tools/src/"
  },
  "keywords": [
    "claude-code",
    "plannotator",
    "orchestration"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/MonsieurBarti/The-Forge-Flow-CC.git"
  },
  "license": "MIT",
  "author": "MonsieurBarti",
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "proper-lockfile": "^4.1.2",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.0",
    "@types/proper-lockfile": "^4.1.4",
    "fast-check": "^4.6.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0",
    "zod": "^4.3.6"
  }
}
